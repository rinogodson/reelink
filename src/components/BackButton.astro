---
interface Props {
  href: string;
  label?: string;
}

const { href, label = "Back" } = Astro.props;
---

<a
  href={href}
  class="font-[Rubik] inline-flex items-center text-[#007AFF] hover:opacity-70 transition-opacity gap-1 text-lg font-medium group"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="w-6 h-6 -ml-2 transition-transform group-hover:-translate-x-0.5"
  >
    <path d="m15 18-6-6 6-6"></path>
  </svg>
  <span>{label}</span>
</a>
