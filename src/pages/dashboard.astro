---
import { db, auth } from "../lib/auth";
import { links } from "../db/schema";
import { eq, desc } from "drizzle-orm";
import BaseLayout from "../layouts/BaseLayout.astro";
import UserHeader from "../components/UserHeader.astro";
import reelink from "../assets/reelink.svg";
import Button from "../components/Button.astro";

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) {
  return Astro.redirect("/");
}

const userLinks = await db
  .select()
  .from(links)
  .where(eq(links.userId, session.user.id))
  .orderBy(desc(links.createdAt));
---

<BaseLayout title="Dashboard | Reelink">
  <div class="max-w-xl mx-auto h-screen py-12 px-6 text-white">
    <div
      class="flex w-full justify-center saturate-0 opacity-30 items-center mb-8"
    >
      <img src={reelink.src} alt="logo" class="h-8" />
    </div>

    <UserHeader
      name={session.user.textName || session.user.name}
      image={session.user.image}
      linkTail={session.user.linkTail}
    />

    <div class="mt-12">
      {
        userLinks.length === 0 ? (
          <p class="text-zinc-400 text-center">
            You haven't created any links yet.
          </p>
        ) : (
          <div class="flex flex-col w-full max-w-xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-6">Your Links</h2>

            <div class="flex flex-col gap-4 pb-32">
              {userLinks.map((link) => (
                <a
                  href={`/links/${link.id}`}
                  class="flex items-center justify-between p-6 bg-[#161f28] border border-black rounded-3xl hover:bg-[#1c2733] transition-colors shadow-[0px_2px_29.1px_rgba(0,0,0,0.5),inset_0px_-2px_3px_rgba(0,0,0,0.25),inset_0px_1px_1px_rgba(255,255,255,0.2)] text-shadow-[0_1px_1px_rgba(0,0,0,0.2)]"
                >
                  <span class="text-2xl font-bold text-white max-w-[10ch] overflow-hidden text-ellipsis whitespace-nowrap">
                    {link.name}
                  </span>
                  <span class="px-4 py-1.5 text-sm font-semibold text-zinc-300 bg-[#0f151c] border border-[#232e3a] rounded-full shadow-[inset_0px_0px_3px_rgba(0,0,0,0.25)] text-shadow-[0_1px_1px_rgba(0,0,0,0.2)]">
                    {new Date(link.createdAt).toLocaleDateString("en-US", {
                      month: "long",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </span>
                </a>
              ))}
            </div>
          </div>
        )
      }
      <a
        href="/links/create"
        class="fixed bottom-10 left-1/2 -translate-x-1/2 z-50"
      >
        <Button
          label="New REELINK"
          classLI="px-8 py-3 text-lg font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white"
        />
      </a>
    </div>
  </div>

  <script>
    import { authClient } from "../lib/auth-client";

    // Handle page load
    window.addEventListener("load", () => {
      document.body.classList.add("loaded");
      // @ts-ignore
      window.hideLoading?.();
    });

    if (document.readyState === "complete") {
      document.body.classList.add("loaded");
      // @ts-ignore
      window.hideLoading?.();
    }

    document.getElementById("logout")?.addEventListener("click", async () => {
      // @ts-ignore
      window.showLoading?.();
      try {
        await authClient.signOut();
        window.location.href = "/";
      } catch (err) {
        console.error("Logout failed:", err);
        // @ts-ignore
        window.hideLoading?.();
        alert("Failed to logout. Please try again.");
      }
    });
  </script>
</BaseLayout>
