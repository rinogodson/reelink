---
import { env } from "cloudflare:workers";
import { getDB, getAuth } from "../lib/auth";
import { links } from "../db/schema";
import { eq, desc } from "drizzle-orm";
import BaseLayout from "../layouts/BaseLayout.astro";
import UserHeader from "../components/UserHeader.astro";
import link from "../assets/link.svg";

import Button from "../components/Button.astro";

const auth = getAuth(env);
const db = getDB(env);

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) {
  return Astro.redirect("/");
}

const INITIAL_LOAD_LIMIT = 10;
const userLinks = await db
  .select()
  .from(links)
  .where(eq(links.userId, session.user.id))
  .orderBy(desc(links.createdAt))
  .limit(INITIAL_LOAD_LIMIT);

const totalLinksCount = await db
  .select({ count: links.id })
  .from(links)
  .where(eq(links.userId, session.user.id));
const totalLinks = totalLinksCount.length;
---

<BaseLayout title="Dashboard | Reelink">
  <div class="max-w-xl mx-auto h-screen py-12 px-6 text-white">
    <UserHeader
      name={session.user.textName || session.user.name}
      image={session.user.image}
      linkTail={session.user.linkTail}
    />

    <div class="mt-12">
      {
        userLinks.length === 0 ? (
          <p class="text-zinc-400 text-center" id="no-links-message">
            You haven't created any links yet.
          </p>
        ) : (
          <div class="flex flex-col w-full max-w-xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-6">Your Links</h2>

            <div class="flex flex-col gap-4 pb-32" id="links-container">
              {userLinks.map((link) => (
                <a
                  href={`/links/${link.id}`}
                  class="flex items-center justify-between p-4 bg-[#161f28] border border-black rounded-3xl hover:bg-[#1c2733] transition-colors shadow-[0px_2px_29.1px_rgba(0,0,0,0.5),inset_0px_-2px_3px_rgba(0,0,0,0.25),inset_0px_1px_1px_rgba(255,255,255,0.2)] text-shadow-[0_1px_1px_rgba(0,0,0,0.2)]"
                >
                  <div class="flex flex-col gap-0.5 overflow-hidden">
                    <span class="text-xl font-bold text-white truncate no-ellipsis whitespace-nowrap">
                      {link.name}
                    </span>
                    <span class="text-xs text-zinc-400">
                      {new Date(link.createdAt).toLocaleDateString("en-US", {
                        month: "long",
                        day: "numeric",
                        year: "numeric",
                      })}
                    </span>
                  </div>
                  <span class="text-zinc-500 font-bold">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </span>
                </a>
              ))}
            </div>
            {totalLinks > INITIAL_LOAD_LIMIT && (
              <div id="sentinel" class="text-center text-zinc-400 py-4">
                Loading more links...
              </div>
            )}
          </div>
        )
      }
      <div
        class="fixed h-[20vh] bg-linear-to-t from-[#0b0b0b] to-transparent bottom-0 w-full flex justify-center items-end pointer-events-none left-1/2 -translate-x-1/2 z-50"
      >
        <a
          href="/links/create"
          class="h-fit w-full text-center pointer-events-auto py-4 pb-10"
        >
          <Button
            label="New REELINK"
            icon={link}
            classLI="px-4 py-3 text-lg font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white"
          />
        </a>
      </div>
    </div>
  </div>
  <script
    define:vars={{
      initialOffset: userLinks.length,
      limit: INITIAL_LOAD_LIMIT,
      totalLinks,
    }}
  >
    const linksContainer = document.getElementById("links-container");
    const sentinel = document.getElementById("sentinel");

    let offset = initialOffset;
    let loading = false;

    const visibilityObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.style.visibility = "visible";
            entry.target.style.height = "auto";
          } else {
            entry.target.style.visibility = "hidden";
            entry.target.style.height = `${entry.target.offsetHeight}px`;
          }
        });
      },
      { rootMargin: "200px 0px 200px 0px" },
    );

    const fetchLinks = async () => {
      if (loading || offset >= totalLinks) {
        return;
      }
      loading = true;
      if (sentinel) sentinel.textContent = "Loading more links...";

      try {
        const response = await fetch(
          `/api/links/list?offset=${offset}&limit=${limit}`,
        );
        if (!response.ok) {
          throw new Error("Failed to fetch links");
        }
        const newLinks = await response.json();

        if (newLinks.length > 0) {
          newLinks.forEach((link) => {
            const linkElement = document.createElement("a");
            linkElement.href = `/links/${link.id}`;
            linkElement.className =
              "flex items-center justify-between p-4 bg-[#161f28] border border-black rounded-3xl hover:bg-[#1c2733] transition-colors shadow-[0px_2px_29.1px_rgba(0,0,0,0.5),inset_0px_-2px_3px_rgba(0,0,0,0.25),inset_0px_1px_1px_rgba(255,255,255,0.2)] text-shadow-[0_1px_1px_rgba(0,0,0,0.2)]";
            linkElement.innerHTML = `
              <div class="flex flex-col gap-0.5 overflow-hidden">
                <span class="text-xl font-bold text-white truncate no-ellipsis whitespace-nowrap">
                  ${link.name}
                </span>
                <span class="text-xs text-zinc-400">
                  ${new Date(link.createdAt).toLocaleDateString("en-US", {
                    month: "long",
                    day: "numeric",
                    year: "numeric",
                  })}
                </span>
              </div>
              <span class="text-zinc-500 font-bold">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            `;
            linksContainer?.appendChild(linkElement);
            visibilityObserver.observe(linkElement);
          });
          offset += newLinks.length;
          if (sentinel) sentinel.textContent = "Loading more links...";
        }

        if (offset >= totalLinks) {
          if (sentinel) sentinel.textContent = "No more links";
          observer.unobserve(sentinel);
        }
      } catch (error) {
        console.error("Error fetching more links:", error);
        if (sentinel) sentinel.textContent = "Error loading links.";
      } finally {
        loading = false;
      }
    };

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        fetchLinks();
      }
    });

    if (sentinel) {
      observer.observe(sentinel);
    }

    document
      .querySelectorAll("#links-container > a")
      .forEach((el) => visibilityObserver.observe(el));
  </script>
</BaseLayout>
