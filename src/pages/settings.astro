---
import { env } from "cloudflare:workers";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAuth } from "../lib/auth";
import Input from "../components/Input.astro";
import Button from "../components/Button.astro";
import BackButton from "../components/BackButton.astro";
import copy from "../assets/copy.svg";

const auth = getAuth(env);

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) {
  return Astro.redirect("/");
}

const user = session.user;
---

<BaseLayout title="Settings | Reelink">
  <div
    class="text-[#E9E9E9] min-h-screen font-[Inter] items-center flex flex-col gap-4 pb-20 px-4"
  >
    <div
      class="h-[30%] w-full max-w-md justify-center flex flex-col gap-4 mt-10"
    >
      <BackButton href="/dashboard" label="Dashboard" />
      <h1 class="text-4xl font-medium w-full text-center">Settings</h1>
    </div>

    <div class="flex flex-col gap-6 mt-10 w-full md:w-[50%] items-center">
      <div class="w-full text-center max-w-md gap-7 flex flex-col items-center">
        <div class="w-full text-center max-w-md flex flex-col">
          <label
            for="textName"
            class="font-[Rubik] text-xl opacity-50 mb-1 uppercase tracking-wider transition-all duration-200"
          >
            Instagram Account Link
          </label>
          <Input label="IG Acc Link" id="igAcc" value={user.igAcc || ""} />
        </div>

        <div
          class="flex text-center flex-col gap-3 relative w-full max-w-md has-value"
        >
          <label
            for="textName"
            class="mt-5 font-[Rubik] text-xl opacity-50 mb-1 uppercase tracking-wider transition-all duration-200"
          >
            Display Name
          </label>
          <label
            for="textName"
            id="label-textName"
            class="font-[Jaro] text-4xl uppercase tracking-wider transition-all duration-200"
          >
            {user.textName || "Display Name"}
          </label>
          <Input
            label="Display Name"
            id="textName"
            value={user.textName || ""}
          />
        </div>

        <div
          class="flex text-center flex-col relative w-full max-w-md has-value"
        >
          <label
            for="textName"
            class="mt-5 font-[Rubik] text-xl opacity-50 mb-1 uppercase tracking-wider transition-all duration-200"
          >
            Bio LInk
          </label>
          <label
            for="linkTail"
            id="label-linkTail"
            class="text-2xl font-semibold transition-all duration-200"
          >
            <div class="flex items-center justify-center gap-1 flex-col mt-4">
              <div
                id="copy-btn"
                class="bg-white/10 px-6 font-[Rubik] rounded-full flex justify-center items-center gap-3 border border-white/20 py-3 w-fit text-2xl shadow-[0px_2px_29.1px_rgba(0,0,0,0.5),inset_0px_-2px_3px_rgba(0,0,0,0.25),inset_0px_3px_3px_rgba(255,255,255,0.1)] text-shadow-[0_1px_2px_rgba(0,0,0,0.5)] cursor-pointer"
              >
                <img src={copy.src} alt="Copy Icon" class="h-5 w-5" />
                <div id="final-link">reelink.cc/{user.linkTail}</div>
              </div>
            </div>
          </label>
          <div class="mt-2">
            <Input
              label="Link Tail"
              id="linkTail"
              value={user.linkTail || ""}
            />
          </div>
        </div>

        <div class="flex gap-4 justify-between w-full items-center">
          <Button
            id="logout"
            label="Logout"
            classLI="mt-10 px-8 font-bold from-[#D01114] to-[#880507] border-[#212121] rounded-full bg-linear-to-b text-white "
          />
          <Button
            id="save-settings"
            label="Save Changes"
            classLI="mt-10 px-8 font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white "
          />
        </div>
      </div>
    </div>

    <script>
      import { authClient } from "../lib/auth-client";

      const nameInput = document.getElementById("textName") as HTMLInputElement;
      const nameLabel = document.getElementById("label-textName");
      const nameWrapper = nameLabel?.parentElement;

      nameInput?.addEventListener("input", () => {
        const val = nameInput.value;
        if (nameLabel)
          nameLabel.textContent = val.length > 0 ? val : "Display Name";
        if (val.length > 0) nameWrapper?.classList.add("has-value");
        else nameWrapper?.classList.remove("has-value");
      });

      const tailInput = document.getElementById("linkTail") as HTMLInputElement;
      const tailPreview = document.getElementById("preview-tail");
      const tailWrapper =
        document.getElementById("label-linkTail")?.parentElement;
      const finalLinkElem = document.getElementById("final-link");

      tailInput?.addEventListener("input", () => {
        const val = tailInput.value;
        if (tailPreview)
          tailPreview.textContent = val.length > 0 ? val : "link-tail";
        if (finalLinkElem)
          finalLinkElem.textContent =
            val.length > 0 ? `reelink.cc/${val}` : "reelink.cc/";
        if (val.length > 0) tailWrapper?.classList.add("has-value");
        else tailWrapper?.classList.remove("has-value");
      });

      const copyBtn = document.getElementById("copy-btn");
      copyBtn?.addEventListener("click", async () => {
        if (finalLinkElem?.textContent) {
          try {
            await navigator.clipboard.writeText(finalLinkElem.textContent);
            const originalHTML = copyBtn.innerHTML;
            copyBtn.innerHTML = `<div class="text-center w-full">Copied!</div>`;
            setTimeout(() => {
              copyBtn.innerHTML = originalHTML;
            }, 2000);
          } catch (err) {
            alert("Failed to copy.");
          }
        }
      });

      const saveBtn = document.getElementById("save-settings");

      saveBtn?.addEventListener("click", async () => {
        const textName = nameInput.value;
        const igAcc = (document.getElementById("igAcc") as HTMLInputElement)
          .value;
        const linkTail = tailInput.value;

        if (!textName || !igAcc || !linkTail) {
          alert("Please fill in all fields.");
          return;
        }

        const igRegex =
          /^https:\/\/(www\.)?instagram\.com\/[a-zA-Z0-9._]+\/?(\?.*)?$/;
        if (!igRegex.test(igAcc)) {
          alert("Invalid Instagram Account Link");
          return;
        }

        if (/\s/.test(linkTail)) {
          alert("Link Tail cannot contain spaces");
          return;
        }

        if (textName.length >= 18) {
          alert("Display Name must be less than 18 characters");
          return;
        }

        // @ts-ignore
        window.showLoading?.();

        try {
          const response = await fetch("/api/user/update", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ textName, igAcc, linkTail }),
          });

          if (response.ok) {
            window.location.href = "/dashboard";
          } else {
            const err = await response.text();
            alert("Failed to update settings: " + err);
            // @ts-ignore
            window.hideLoading?.();
          }
        } catch (err) {
          console.error("Update error:", err);
          // @ts-ignore
          window.hideLoading?.();
          alert("An unexpected error occurred.");
        }
      });

      document.getElementById("logout")?.addEventListener("click", async () => {
        // @ts-ignore
        window.showLoading?.();
        try {
          await authClient.signOut();
          window.location.href = "/";
        } catch (err) {
          console.error("Logout failed:", err);
          // @ts-ignore
          window.hideLoading?.();
          alert("Failed to logout. Please try again.");
        }
      });
    </script>
  </div>
</BaseLayout>
