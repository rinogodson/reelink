---
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Onboarding | Reelink</title>
</head>
<body>
    <div id="onboarding-form" style="max-width: 400px; margin: 50px auto; font-family: sans-serif;">
        <h1>Welcome!</h1>
        <p>Complete your profile to get started.</p>
        
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div>
                <label for="linkTail">Link Tail (e.g. /my-links):</label><br>
                <input type="text" id="linkTail" placeholder="my-links" style="width: 100%; padding: 8px; margin-top: 5px;">
            </div>
            <div>
                <label for="igAcc">Instagram Account (without @):</label><br>
                <input type="text" id="igAcc" placeholder="instagram_user" style="width: 100%; padding: 8px; margin-top: 5px;">
            </div>
            <div>
                <label for="textName">Display Name for Links:</label><br>
                <input type="text" id="textName" placeholder="My Awesome Links" style="width: 100%; padding: 8px; margin-top: 5px;">
            </div>
            
            <button id="finish" style="padding: 10px; background: #007bff; color: white; border: none; cursor: pointer; margin-top: 10px;">
                Complete Onboarding
            </button>
        </div>
    </div>

    <div id="success-state" style="display: none; max-width: 400px; margin: 50px auto; font-family: sans-serif; text-align: center;">
        <h1>You're all set!</h1>
        <p>Your Reelink is ready:</p>
        
        <div style="background: #f4f4f4; padding: 15px; border-radius: 8px; margin: 20px 0; display: flex; align-items: center; justify-content: space-between; gap: 10px;">
            <code id="final-link" style="font-weight: bold; font-size: 1.1rem; word-break: break-all;">reelin.cc/</code>
            <button id="copy-btn" style="padding: 8px 12px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; white-space: nowrap;">
                Copy
            </button>
        </div>

        <button id="continue" style="padding: 12px 20px; background: #007bff; color: white; border: none; cursor: pointer; width: 100%; border-radius: 4px; font-size: 1rem;">
            Continue to Dashboard
        </button>
    </div>

    <script>
    const onboardingForm = document.getElementById("onboarding-form");
    const successState = document.getElementById("success-state");
    const finalLinkElem = document.getElementById("final-link");
    const copyBtn = document.getElementById("copy-btn");
    const continueBtn = document.getElementById("continue");

    document.getElementById("finish")?.addEventListener("click", async () => {
        const linkTail = (document.getElementById("linkTail") as HTMLInputElement).value;
        const igAcc = (document.getElementById("igAcc") as HTMLInputElement).value;
        const textName = (document.getElementById("textName") as HTMLInputElement).value;

        if (!linkTail || !igAcc || !textName) {
            alert("Please fill in all fields.");
            return;
        }

        const response = await fetch("/api/complete-onboarding", { 
            method: "POST",
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ linkTail, igAcc, textName })
        });

        if (response.ok) {
            if (onboardingForm && successState && finalLinkElem) {
                const fullLink = `reelin.cc/${linkTail}`;
                finalLinkElem.textContent = fullLink;
                onboardingForm.style.display = "none";
                successState.style.display = "block";
            } else {
                window.location.href = "/dashboard";
            }
        } else {
            alert("Failed to complete onboarding.");
        }
    });

    copyBtn?.addEventListener("click", async () => {
        if (finalLinkElem?.textContent) {
            try {
                await navigator.clipboard.writeText(finalLinkElem.textContent);
                const originalText = copyBtn.textContent;
                copyBtn.textContent = "Copied!";
                copyBtn.style.background = "#218838";
                setTimeout(() => {
                    copyBtn.textContent = originalText;
                    copyBtn.style.background = "#28a745";
                }, 2000);
            } catch (err) {
                alert("Failed to copy to clipboard.");
            }
        }
    });

    continueBtn?.addEventListener("click", () => {
        window.location.href = "/dashboard";
    });
    </script>
</body>
</html>
