---
import BaseLayout from "../layouts/BaseLayout.astro";
import Input from "../components/Input.astro";
import Button from "../components/Button.astro";
---

<BaseLayout>
  <div
    id="onboarding-form"
    class="text-[#E9E9E9] h-screen font-[Inter] items-center flex flex-col gap-4"
  >
    <h1 class="text-4xl font-medium h-[30%] justify-center items-center flex">
      Create Account
    </h1>

    <div class="flex flex-col gap-6 mt-10 w-full md:w-[50%] items-center">
      <div class="w-full text-center max-w-sm">
        <Input label="IG Acc Link" id="igAcc" />
      </div>

      <div class="flex text-center flex-col gap-3 relative w-full max-w-sm">
        <label
          for="textName"
          id="label-textName"
          class="font-[Jaro] text-4xl uppercase tracking-wider transition-all duration-200"
        >
          Display Name
        </label>
        <Input label="Display Name" id="textName" />
      </div>

      <div class="flex text-center flex-col relative w-full max-w-sm">
        <label
          for="linkTail"
          id="label-linkTail"
          class="text-2xl font-semibold transition-all duration-200"
        >
          <span>reelink.cc/</span><span id="preview-tail" class="text-blue-400"
            >link-tail</span
          >
        </label>
        <div class="mt-2">
          <Input label="Link Tail" id="linkTail" />
        </div>
      </div>

      <Button
        id="finish"
        label="Continue"
        classLI="mt-10 px-8 font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white "
      />
    </div>
  </div>

  <div
    id="success-state"
    style="display: none;"
    class="text-[#E9E9E9] h-screen font-[Inter] flex flex-col gap-4 justify-center items-center"
  >
    <h1
      class="text-4xl font-medium h-[30%] justify-center items-center flex flex-col gap-2"
    >
      You're all set!
    </h1>
    <div class="flex items-center justify-center gap-1 flex-col">
      <div
        id="copy-btn"
        class="bg-white/10 px-6 font-[Rubik] rounded-full border border-white/20 py-3 w-fit text-2xl shadow-[0px_2px_29.1px_rgba(0,0,0,0.5),inset_0px_-2px_3px_rgba(0,0,0,0.25),inset_0px_3px_3px_rgba(255,255,255,0.1)] text-shadow-[0_1px_2px_rgba(0,0,0,0.5)] cursor-pointer"
      >
        <div id="final-link">reelink.cc/</div>
      </div>
      <label class="text-sm text-gray-400 mt-2">Click the link to copy</label>
      <Button
        id="continue"
        label="Continue to Dashboard"
        classLI="mt-10 px-8 font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white "
      />
    </div>
  </div>

  <style>
    .has-value #label-textName {
      transform: translateY(-5px);
      color: #fff;
    }

    .has-value #label-linkTail {
      transform: translateY(-5px);
    }
  </style>

  <script>
    const onboardingForm = document.getElementById("onboarding-form");
    const successState = document.getElementById("success-state");
    const finalLinkElem = document.getElementById("final-link");
    const copyBtn = document.getElementById("copy-btn");
    const continueBtn = document.getElementById("continue");

    // Handle page load
    window.addEventListener('load', () => {
      document.body.classList.add('loaded');
      // @ts-ignore
      window.hideLoading?.();
    });

    if (document.readyState === 'complete') {
      document.body.classList.add('loaded');
      // @ts-ignore
      window.hideLoading?.();
    }

    document.getElementById("finish")?.addEventListener("click", async () => {
      const linkTail = (document.getElementById("linkTail") as HTMLInputElement)
        .value;
      const igAcc = (document.getElementById("igAcc") as HTMLInputElement)
        .value;
      const textName = (document.getElementById("textName") as HTMLInputElement)
        .value;

      if (!linkTail || !igAcc || !textName) {
        alert("Please fill in all fields.");
        return;
      }

      // @ts-ignore
      window.showLoading?.();

      try {
        const response = await fetch("/api/complete-onboarding", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ linkTail, igAcc, textName }),
        });

        if (response.ok) {
          if (onboardingForm && successState && finalLinkElem) {
            finalLinkElem.textContent = `reelink.cc/${linkTail}`;
            onboardingForm.style.display = "none";
            successState.style.display = "flex";
          } else {
            window.location.href = "/dashboard";
          }
        } else {
          alert("Failed to complete onboarding.");
        }
      } finally {
        // @ts-ignore
        window.hideLoading?.();
      }
    });

    copyBtn?.addEventListener("click", async () => {
      if (finalLinkElem?.textContent) {
        try {
          await navigator.clipboard.writeText(finalLinkElem.textContent);
          const originalHTML = copyBtn.innerHTML;
          copyBtn.innerHTML = `<div class="text-center w-full">Copied!</div>`;
          setTimeout(() => {
            copyBtn.innerHTML = originalHTML;
          }, 2000);
        } catch (err) {
          alert("Failed to copy.");
        }
      }
    });

    continueBtn?.addEventListener("click", () => {
      window.location.href = "/dashboard";
    });

    const nameInput = document.getElementById("textName") as HTMLInputElement;
    const nameLabel = document.getElementById("label-textName");
    const nameWrapper = nameLabel?.parentElement;

    nameInput?.addEventListener("input", () => {
      const val = nameInput.value;
      if (nameLabel)
        nameLabel.textContent = val.length > 0 ? val : "Display Name";
      if (val.length > 0) nameWrapper?.classList.add("has-value");
      else nameWrapper?.classList.remove("has-value");
    });

    const tailInput = document.getElementById("linkTail") as HTMLInputElement;
    const tailPreview = document.getElementById("preview-tail");
    const tailWrapper =
      document.getElementById("label-linkTail")?.parentElement;

    tailInput?.addEventListener("input", () => {
      const val = tailInput.value;
      if (tailPreview)
        tailPreview.textContent = val.length > 0 ? val : "link-tail";
      if (val.length > 0) tailWrapper?.classList.add("has-value");
      else tailWrapper?.classList.remove("has-value");
    });
  </script>
</BaseLayout>
