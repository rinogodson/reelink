---
import { env } from "cloudflare:workers";
import { getDB, getAuth } from "../../lib/auth";
import { links } from "../../db/schema";
import { eq, and } from "drizzle-orm";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackButton from "../../components/BackButton.astro";
import Button from "../../components/Button.astro";
import Input from "../../components/Input.astro";

const auth = getAuth(env);
const db = getDB(env);

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) {
  return Astro.redirect("/");
}

const link = await db
  .select()
  .from(links)
  .where(and(eq(links.id, id), eq(links.userId, session.user.id)))
  .then((res) => res[0]);

if (!link) {
  return Astro.redirect("/dashboard");
}

const createdDate = new Date(link.createdAt);
const dateStr = createdDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const timeStr = createdDate.toLocaleTimeString("en-US", {
  hour: "numeric",
  minute: "2-digit",
  second: "2-digit",
});
---

<BaseLayout title={`${link.name} | Reelink`}>
  <div class="max-w-150 mx-auto p-6 font-sans flex flex-col min-h-svh">
    <div class="h-[30%] w-full max-w-sm justify-center flex flex-col gap-4">
      <BackButton href="/dashboard" label="Dashboard" />
    </div>

    <h1
      class="text-3xl mt-4 font-extrabold text-white mb-8 truncate tracking-wide"
    >
      {link.name}
    </h1>

    <div class="flex flex-col gap-6">
      <div
        class="w-full text-start text-[#ECECEC] max-w-sm gap-3 flex flex-col"
      >
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          Destination Link
        </label>
        <Input
          label="Destination Link"
          value={link.destURL}
          id="destURL"
          readonly={true}
        />
      </div>
      <div
        class="w-full text-start text-[#ECECEC] max-w-sm gap-3 flex flex-col"
      >
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          Terms
        </label>
        <div id="termInputContainer" class="relative w-full" style="display: none;">
          <Input label="Add a term..." id="termInput" />
          <button
            id="addTermBtn"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-4xl text-white/50 hover:text-white md:hidden flex items-center justify-center h-full"
            type="button"
          >
            +
          </button>
        </div>
        <div id="termsList" class="flex flex-wrap gap-2 mt-2">
        </div>
      </div>
    </div>

    <div
      class="mt-8 flex flex-col gap-2 text-[#4f5460] text-lg font-medium tracking-wide"
    >
      <p>Created on: {dateStr}</p>
      <p>Time: {timeStr}</p>
    </div>

    <div id="terms-data" data-terms={JSON.stringify(link.terms)}></div>

    <div class="mt-auto pt-16 pb-4 flex justify-between gap-4">
      <Button
        id="deleteBtn"
        label="Delete"
        data-id={link.id}
        classLI="mt-10 px-8 font-bold from-[#D01114] to-[#880507] border-[#212121] rounded-full bg-linear-to-b text-white "
      />

      <Button
        id="editBtn"
        label="Edit This"
        classLI="mt-10 px-8 font-bold from-[#009CFF] to-[#0061F5] border-[#212121] rounded-full bg-linear-to-b text-white "
      />
    </div>
  </div>

  <script>
    const editBtn = document.getElementById("editBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const destInput = document.getElementById("destURL") as HTMLInputElement;
    const termInput = document.getElementById("termInput") as HTMLInputElement;
    const termInputContainer = document.getElementById("termInputContainer");
    const termsList = document.getElementById("termsList");
    const addTermBtn = document.getElementById("addTermBtn");
    const termsData = document.getElementById("terms-data");
    
    let terms: string[] = JSON.parse(termsData?.dataset.terms || "[]");
    let isEditing = false;

    function renderTerms() {
      if (!termsList) return;
      termsList.innerHTML = "";
      terms.forEach((term, index) => {
        const chip = document.createElement("div");
        chip.className = "flex items-center gap-2 px-3 py-1 bg-white/10 border border-white/10 rounded-full text-white max-w-[150px]";
        
        const text = document.createElement("span");
        text.className = "truncate text-sm font-medium";
        text.textContent = term;
        chip.appendChild(text);

        if (isEditing) {
          const removeBtn = document.createElement("button");
          removeBtn.innerHTML = "×";
          removeBtn.className = "text-lg leading-none opacity-50 hover:opacity-100 focus:outline-none";
          removeBtn.onclick = () => {
            terms = terms.filter((_, i) => i !== index);
            renderTerms();
          };
          chip.appendChild(removeBtn);
        }
        
        termsList.appendChild(chip);
      });
    }

    renderTerms();

    function addTerm() {
      const value = termInput.value.trim();
      if (value && !terms.includes(value)) {
        terms.push(value);
        termInput.value = "";
        renderTerms();
      }
    }

    termInput?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        addTerm();
      }
    });

    addTermBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      addTerm();
    });

    editBtn?.addEventListener("click", async () => {
      if (!isEditing) {
        isEditing = true;
        destInput.removeAttribute("readonly");
        if (termInputContainer) termInputContainer.style.display = "block";
        destInput.focus();
        editBtn.textContent = "Save";
        renderTerms();
      } else {
        let destURL = destInput.value;
        const id = window.location.pathname.split("/").pop();

        if (terms.length === 0 || !destURL) {
          alert("Please fill in all fields and add at least one term.");
          return;
        }

        if (!/^https?:\/\//i.test(destURL)) {
          destURL = "https://" + destURL;
        }

        try {
          new URL(destURL);
        } catch (e) {
          alert("Invalid Destination URL");
          return;
        }

        (window as any).showLoading?.();

        try {
          const response = await fetch("/api/links/update", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id, terms, destURL }),
          });

          if (response.ok) {
            isEditing = false;
            destInput.setAttribute("readonly", "true");
            if (termInputContainer) termInputContainer.style.display = "none";
            editBtn.textContent = "Edit This";
            renderTerms();
          } else {
            const errorText = await response.text();
            alert(errorText || "Failed to update link.");
          }
        } catch (err) {
          alert("An error occurred.");
        } finally {
          (window as any).hideLoading?.();
        }
      }
    });

    deleteBtn?.addEventListener("click", async (e) => {
      const id = (e.target as HTMLButtonElement).dataset.id;
      if (!confirm("Are you sure you want to delete this link?")) return;

      (window as any).showLoading?.();

      try {
        const response = await fetch("/api/links/delete", {
          method: "DELETE",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ id }),
        });

        if (response.ok) {
          window.location.href = "/dashboard";
        } else {
          alert("Failed to delete link.");
          (window as any).hideLoading?.();
        }
      } catch (err) {
        (window as any).hideLoading?.();
        alert("An error occurred.");
      }
    });
  </script>
</BaseLayout>
