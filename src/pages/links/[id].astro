---
import { db, auth } from "../../lib/auth";
import { links } from "../../db/schema";
import { eq, and } from "drizzle-orm";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackButton from "../../components/BackButton.astro";
import Button from "../../components/Button.astro";
import Input from "../../components/Input.astro";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) {
  return Astro.redirect("/");
}

const link = await db
  .select()
  .from(links)
  .where(and(eq(links.id, id), eq(links.userId, session.user.id)))
  .then((res) => res[0]);

if (!link) {
  return Astro.redirect("/dashboard");
}

const createdDate = new Date(link.createdAt);
const dateStr = createdDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const timeStr = createdDate.toLocaleTimeString("en-US", {
  hour: "numeric",
  minute: "2-digit",
  second: "2-digit",
});
---

<BaseLayout title={`${link.name} | Reelink`}>
  <div class="max-w-150 mx-auto p-6 font-sans flex flex-col min-h-screen">
    <div class="h-[30%] w-full max-w-sm justify-center flex flex-col gap-4">
      <BackButton href="/dashboard" label="Dashboard" />
    </div>

    <h1
      class="text-3xl mt-4 font-extrabold text-white mb-8 truncate tracking-wide"
    >
      {link.name}
    </h1>

    <div class="flex flex-col gap-6">
      <div
        class="w-full text-start text-[#ECECEC] max-w-sm gap-3 flex flex-col"
      >
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          REEL LINK
        </label>
        <Input
          label="Reel Link"
          value={link.reelURL}
          id="reelURL"
          readonly={true}
        />
      </div>
      <div
        class="w-full text-start text-[#ECECEC] max-w-sm gap-3 flex flex-col"
      >
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          Destination Link
        </label>
        <Input
          label="Destination Link"
          value={link.destURL}
          id="destURL"
          readonly={true}
        />
      </div>
    </div>

    <div
      class="mt-8 flex flex-col gap-2 text-[#4f5460] text-lg font-medium tracking-wide"
    >
      <p>Created on: {dateStr}</p>
      <p>Time: {timeStr}</p>
    </div>

    <div class="mt-auto pt-16 pb-4 flex justify-between gap-4">
      <Button
        id="deleteBtn"
        label="Delete"
        data-id={link.id}
        classLI="mt-10 px-8 font-bold from-[#D01114] to-[#880507] border-[#212121] rounded-full bg-linear-to-b text-white "
      />

      <Button
        id="editBtn"
        label="Edit This"
        classLI="mt-10 px-8 font-bold from-[#009CFF] to-[#0061F5] border-[#212121] rounded-full bg-linear-to-b text-white "
      />
    </div>
  </div>

  <script>
    window.addEventListener("load", () => {
      document.body.classList.add("loaded");
      (window as any).hideLoading?.();
    });

    if (document.readyState === "complete") {
      document.body.classList.add("loaded");
      (window as any).hideLoading?.();
    }

    const editBtn = document.getElementById("editBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const reelInput = document.getElementById("reelURL") as HTMLInputElement;
    const destInput = document.getElementById("destURL") as HTMLInputElement;

    editBtn?.addEventListener("click", async () => {
      if (editBtn.textContent?.trim() === "Edit This") {
        reelInput.removeAttribute("readonly");
        destInput.removeAttribute("readonly");
        reelInput.focus();
        editBtn.textContent = "Save";
      } else {
        const reelURL = reelInput.value;
        const destURL = destInput.value;
        const id = window.location.pathname.split("/").pop();

        if (!reelURL || !destURL) {
          alert("Please fill in all fields.");
          return;
        }

        (window as any).showLoading?.();

        try {
          const response = await fetch("/api/links/update", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id, reelURL, destURL }),
          });

          if (response.ok) {
            reelInput.setAttribute("readonly", "true");
            destInput.setAttribute("readonly", "true");
            editBtn.textContent = "Edit This";
          } else {
            alert("Failed to update link.");
          }
        } catch (err) {
          alert("An error occurred.");
        } finally {
          (window as any).hideLoading?.();
        }
      }
    });

    deleteBtn?.addEventListener("click", async (e) => {
      const id = (e.target as HTMLButtonElement).dataset.id;
      if (!confirm("Are you sure you want to delete this link?")) return;

      (window as any).showLoading?.();

      try {
        const response = await fetch("/api/links/delete", {
          method: "DELETE",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ id }),
        });

        if (response.ok) {
          window.location.href = "/dashboard";
        } else {
          alert("Failed to delete link.");
          (window as any).hideLoading?.();
        }
      } catch (err) {
        (window as any).hideLoading?.();
        alert("An error occurred.");
      }
    });
  </script>
</BaseLayout>
