---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackButton from "../../components/BackButton.astro";
import reelink from "../../assets/reelink.svg";
import Input from "../../components/Input.astro";
import Button from "../../components/Button.astro";
---

<BaseLayout title="Create Link | Reelink">
  <div class="w-full h-screen flex justify-center">
    <div
      style=" font-family: sans-serif; color: white; padding: 0 20px;"
      class="w-full md:max-w-2xl mt-5 justify-center"
    >
      <BackButton href="/dashboard" label="Dashboard" />
      <div
        class="w-full h-[20%] flex justify-center md:mb-15 md:mt-0 mb-5 mt-10"
      >
        <img src={reelink.src} alt="logo" class="md:w-60 w-45" />
      </div>

      <div
        style="display: flex; align-items: center; flex-direction: column; gap: 1rem; margin-top: 20px;"
      >
        <div class="w-full text-center max-w-sm gap-3 flex flex-col">
          <label
            class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
          >
            Link NAME
          </label>
          <Input label="Link Name" id="name" />
        </div>
        <div class="w-full text-center max-w-sm gap-3 flex flex-col">
          <label
            class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
          >
            Destination Link
          </label>
          <Input label="Enter Destination" id="destURL" />
        </div>
        <div class="w-full text-center max-w-sm gap-3 flex flex-col">
          <label
            class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
          >
            Terms
          </label>
          <div class="relative w-full">
            <Input label="Add a term..." id="termInput" />
            <button
              id="addTermBtn"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-4xl text-white/50 hover:text-white md:hidden flex items-center justify-center h-full"
              type="button"
            >
              +
            </button>
          </div>
          <div id="termsList" class="flex flex-wrap gap-2 mt-2 justify-center">
          </div>
        </div>

        <Button
          id="createBtn"
          label="Create Link"
          classLI="mt-10 px-8 absolute bottom-10 font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white "
        />
      </div>
    </div>
  </div>

  <script>
    import { authClient } from "../../lib/auth-client";

    const termInput = document.getElementById("termInput") as HTMLInputElement;
    const addTermBtn = document.getElementById("addTermBtn");
    const termsList = document.getElementById("termsList");
    let terms: string[] = [];

    function renderTerms() {
      if (!termsList) return;
      termsList.innerHTML = "";
      terms.forEach((term, index) => {
        const chip = document.createElement("div");
        chip.className = "flex font-[Rubik] items-center gap-2 px-3 py-1 bg-white/10 border border-white/10 rounded-full text-white max-w-[150px] shadow-[0px_2px_2px_rgba(0,0,0,0.40),inset_0px_1px_1px_rgba(255,255,255,0.10)]";
        
        const text = document.createElement("span");
        text.className = "truncate text-sm font-medium";
        text.textContent = term;
        
        const deleteBtn = document.createElement("button");
        deleteBtn.innerHTML = "×";
        deleteBtn.className = "text-lg leading-none opacity-50 hover:opacity-100 focus:outline-none";
        deleteBtn.onclick = () => {
          terms = terms.filter((_, i) => i !== index);
          renderTerms();
        };

        chip.appendChild(text);
        chip.appendChild(deleteBtn);
        termsList.appendChild(chip);
      });
    }

    function addTerm() {
      const value = termInput.value.trim();
      if (value && !terms.includes(value)) {
        terms.push(value);
        termInput.value = "";
        renderTerms();
      }
    }

    termInput?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        addTerm();
      }
    });

    addTermBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      addTerm();
    });

    document
      .getElementById("createBtn")
      ?.addEventListener("click", async () => {
        const name = (document.getElementById("name") as HTMLInputElement)
          .value;
        let destURL = (document.getElementById("destURL") as HTMLInputElement)
          .value;

        if (!name || terms.length === 0 || !destURL) {
          alert("Please fill in all fields and add at least one term.");
          return;
        }

        if (!/^https?:\/\//i.test(destURL)) {
          destURL = "https://" + destURL;
        }

        try {
          new URL(destURL);
        } catch (e) {
          alert("Invalid Destination URL");
          return;
        }

        // @ts-ignore
        window.showLoading?.();

        try {
          const response = await fetch("/api/links/create", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, terms, destURL }),
          });

          if (response.ok) {
            window.location.href = "/dashboard";
          } else {
            const errorText = await response.text();
            alert("Failed to create link: " + errorText);
            // @ts-ignore
            window.hideLoading?.();
          }
        } catch (e) {
          console.error("Create error:", e);
          // @ts-ignore
          window.hideLoading?.();
          alert("An error occurred.");
        }
      });
  </script>
</BaseLayout>
