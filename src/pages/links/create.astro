---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BackButton from "../../components/BackButton.astro";
import reelink from "../../assets/reelink.svg";
import Input from "../../components/Input.astro";
import Button from "../../components/Button.astro";
---

<BaseLayout title="Create Link | Reelink">
  <div
    style="max-width: 500px; height: 100vh; font-family: sans-serif; color: white; padding: 0 20px;"
    class="mt-5"
  >
    <BackButton href="/dashboard" label="Dashboard" />
    <div
      class="w-full h-[20%] flex justify-center md:justify-start md:mb-15 md:mt-0 mb-5 mt-10"
    >
      <img src={reelink.src} alt="logo" class="md:w-60 w-45" />
    </div>

    <div
      style="display: flex; align-items: center; flex-direction: column; gap: 1rem; margin-top: 20px;"
    >
      <div class="w-full text-center max-w-sm gap-3 flex flex-col">
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          Link NAME
        </label>
        <Input label="Link Name" id="name" />
      </div>
      <div class="w-full text-center max-w-sm gap-3 flex flex-col">
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          Reel's Link
        </label>
        <Input label="Enter Reel" id="reelURL" />
      </div>
      <div class="w-full text-center max-w-sm gap-3 flex flex-col">
        <label
          class="font-[Rubik] text-xl opacity-50 uppercase tracking-wider transition-all duration-200"
        >
          Destination Link
        </label>
        <Input label="Enter Destination" id="destURL" />
      </div>

      <Button
        id="createBtn"
        label="Create Link"
        classLI="mt-10 px-8 absolute bottom-30 font-bold from-[#009CFF] to-[#0061F5] border-[#004DC4] rounded-full bg-linear-to-b text-white "
      />
    </div>
  </div>

  <script>
    import { authClient } from "../../lib/auth-client";

    document
      .getElementById("createBtn")
      ?.addEventListener("click", async () => {
        const name = (document.getElementById("name") as HTMLInputElement)
          .value;
        const reelURL = (document.getElementById("reelURL") as HTMLInputElement)
          .value;
        const destURL = (document.getElementById("destURL") as HTMLInputElement)
          .value;

        if (!name || !reelURL || !destURL) {
          alert("Please fill in all fields.");
          return;
        }

        const reelRegex = /^https:\/\/(www\.)?instagram\.com\/reel\/[a-zA-Z0-9._-]+\/?(\?.*)?$/;
        if (!reelRegex.test(reelURL)) {
          alert("Invalid Instagram Reel Link");
          return;
        }

        try {
          new URL(destURL);
        } catch (e) {
          alert("Invalid Destination URL");
          return;
        }

        // @ts-ignore
        window.showLoading?.();

        try {
          const response = await fetch("/api/links/create", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, reelURL, destURL }),
          });

          if (response.ok) {
            window.location.href = "/dashboard";
          } else {
            const errorText = await response.text();
            alert("Failed to create link: " + errorText);
            // @ts-ignore
            window.hideLoading?.();
          }
        } catch (e) {
          console.error("Create error:", e);
          // @ts-ignore
          window.hideLoading?.();
          alert("An error occurred.");
        }
      });
  </script>
</BaseLayout>
